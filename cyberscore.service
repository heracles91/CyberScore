[Unit]
Description=CyberScore — Gamification Cybersécurité
After=network.target

[Service]
Type=simple
User=cyberscore
Group=cyberscore
WorkingDirectory=/opt/cyberscore
ExecStart=/opt/cyberscore/venv/bin/waitress-serve --host=0.0.0.0 --port=5000 app:app
Restart=on-failure
RestartSec=5
# Redémarre automatiquement si le processus crashe

[Install]
WantedBy=multi-user.target
